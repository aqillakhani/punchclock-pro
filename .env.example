# ============================================================
# PunchClock Pro — Environment Variables (internal-use)
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Node / runtime ---
NODE_ENV=development
LOG_LEVEL=debug

# --- API ---
API_PORT=4000
API_BASE_URL=http://localhost:4000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Database (PostgreSQL + TimescaleDB + PostGIS) ---
DATABASE_URL=postgresql://punchclock:punchclock@localhost:5432/punchclock
DATABASE_POOL_MAX=20
DATABASE_SSL=false

# --- Redis (Socket.io adapter) ---
REDIS_URL=redis://localhost:6379

# --- Auth (self-hosted: bcrypt + JWT) ---
JWT_SECRET=dev-only-secret-replace-in-prod-with-32-plus-random-chars
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# --- Web (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# --- Mobile (Expo) ---
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# --- Build provenance (set to git SHA at deploy time; shown on GET /health) ---
APP_VERSION=dev

# --- Web app URL (used to build links inside transactional emails) ---
WEB_APP_URL=http://localhost:3000

# --- Error tracking (Sentry) — leave DSN blank to disable (default in dev) ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
# Web (Next.js): public DSN + build-time source map upload creds
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Transactional email ---
# EMAIL_PROVIDER=log (default) writes emails to the server log; set to 'resend' to send for real.
EMAIL_PROVIDER=log
RESEND_API_KEY=
EMAIL_FROM=PunchClock Pro <onboarding@resend.dev>

# --- Document storage (S3-compatible: Cloudflare R2 / AWS S3) ---
# Cloudflare R2: S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com, S3_REGION=auto
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
DOCUMENTS_PRESIGN_EXPIRY_SECONDS=900
